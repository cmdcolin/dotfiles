[user]
  email = <colin.diesh@gmail.com>
  name = Colin
  signingkey = A73172047D7555CE
[blame]
  date = short
[pull]
  rebase = true
[push]
  autoSetupRemote = true
[credential]
  helper = cache
[core]
  editor = nvim

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true

[init]
  defaultBranch = main
[commit]
  gpgsign = true

[alias]
  s = status
  a = add
  aa = add .
  c = commit -m
  ca = commit --amend --no-edit
  caa = commit -a --amend --no-edit
  co = checkout
  cob = checkout -b
  d = diff
  dc = diff --cached
  l = log --oneline --graph --all
  b = branch -vv
  p = push
  pl = pull
